# Representative models from unsloth, one per architecture (verified via GGUF metadata).
# Rebuilt from the full unsloth GGUF catalog (https://huggingface.co/unsloth/models).
# All architectures verified against general.architecture in actual GGUF headers.
#
# Used by test/snapshot.mjs for golden-output regression testing.
# Regenerate golden files: npm run test:update-golden

# ── Dense transformers (llamaKvCache + standard handlers) ──
unsloth/Llama-3.2-1B-Instruct-GGUF              # llama
unsloth/Qwen2.5-Coder-0.5B-Instruct-GGUF         # qwen2
unsloth/Qwen3-0.6B-GGUF                          # qwen3
unsloth/Qwen3.5-0.8B-GGUF                        # qwen35 (MTP effectiveLayers)
unsloth/Phi-4-mini-instruct-GGUF                 # phi3
unsloth/granite-4.0-350m-GGUF                    # granite
unsloth/granite-4.0-h-tiny-GGUF                  # granitehybrid
unsloth/SmolLM3-3B-GGUF                          # smollm3
unsloth/ERNIE-4.5-0.3B-PT-GGUF                   # ernie4_5 (dense variant)
unsloth/Apertus-8B-Instruct-2509-GGUF            # apertus
unsloth/grok-2-GGUF                              # grok
unsloth/Seed-OSS-36B-Instruct-GGUF               # seed_oss
unsloth/Hy-MT2-7B-GGUF                           # hunyuan-dense

# ── ISWA dense transformers ──
unsloth/gemma-3-270m-it-GGUF                     # gemma3 (swaPeriodDefault=6)
unsloth/gemma-2-it-GGUF                          # gemma2 (swaPeriodDefault=2, swaDefault=4096)
unsloth/OLMo-2-0425-1B-Instruct-GGUF             # olmo2 (swaPeriodDefault=4)
unsloth/c4ai-command-a-03-2025-GGUF              # cohere2 (swaPeriodDefault=4)

# ── Mistral dense ──
unsloth/Mistral-Medium-3.5-128B-GGUF             # mistral3

# ── Standard MoE (no shared experts) ──
unsloth/Qwen3-30B-A3B-GGUF                       # qwen3moe

# ── MoE with leading dense + shared experts ──
unsloth/ERNIE-4.5-21B-A3B-PT-GGUF                # ernie4_5_moe
unsloth/Hunyuan-A13B-Instruct-GGUF               # hunyuan_moe
unsloth/dots.llm1.inst-GGUF                      # dots1
unsloth/MiniMax-M3-GGUF                          # minimax-m3

# ── Other MoE ──
unsloth/LFM2-8B-A1B-GGUF                         # lfm2_moe (hybrid recurrent MoE)
unsloth/MiniMax-M2.5-GGUF                        # minimax-m2

# ── MLA + MoE ──
unsloth/DeepSeek-R1-GGUF                         # deepseek2 (MLA + MoE)
unsloth/GLM-5-GGUF                               # glm-dsa (DSA + indexer + MTP)
unsloth/DeepSeek-V4-Flash-GGUF                   # deepseek4 (DSV4 sparse attention)
unsloth/Mistral-Small-4-119B-2603-GGUF           # mistral4 (MLA + MoE)

# ── ISWA + MoE ──
unsloth/gemma-4-E2B-it-GGUF                      # gemma4 (shared_kv_layers)
unsloth/gpt-oss-20b-GGUF                         # gpt-oss (swaPeriodDefault=2)
unsloth/Llama-4-Scout-17B-16E-Instruct-GGUF      # llama4 (swaDefault=8192)
unsloth/gemma-3n-E2B-it-GGUF                     # gemma3n (altup + layer_kv_from_start)
unsloth/MiMo-V2.5-GGUF                           # mimo2
unsloth/North-Mini-Code-1.0-GGUF                 # cohere2moe (denseFirst + MTP)
unsloth/Trinity-Large-Preview-GGUF               # afmoe
unsloth/Step-3.7-Flash-GGUF                      # step35

# ── MTP / layer-filter MoE with shared experts ──
unsloth/Qwen3.6-35B-A3B-GGUF                     # qwen35moe (MTP + layerFilter, also has mmproj)
unsloth/Qwen3-Next-80B-A3B-Instruct-GGUF         # qwen3next (layerFilter + sharedExpert)
unsloth/GLM-4-9B-0414-GGUF                       # glm4 (MTP effectiveLayers)
unsloth/GLM-4.7-GGUF                             # glm4moe (MTP + gate_up_exps fused)
unsloth/Ling-1T-GGUF                             # bailingmoe2 (MTP)

# ── Hybrid recurrent/attention ──
unsloth/Falcon-H1-0.5B-Instruct-GGUF             # falcon-h1
unsloth/LFM2-350M-GGUF                           # lfm2
unsloth/NVIDIA-Nemotron-3-Nano-4B-GGUF           # nemotron_h
unsloth/Nemotron-3-Nano-30B-A3B-GGUF             # nemotron_h_moe

# ── Embedding (no KV cache) ──
unsloth/embeddinggemma-300m-GGUF                 # gemma-embedding

# ── Diffusion ──
unsloth/FLUX.1-schnell-GGUF                      # flux
unsloth/LTX-2-GGUF                               # ltxv
unsloth/Qwen-Image-GGUF                          # qwen_image
unsloth/Z-Image-Turbo-GGUF                       # lumina2

# ── Vision-language ──
unsloth/Qwen2.5-VL-7B-Instruct-GGUF              # qwen2vl
unsloth/Qwen3-VL-8B-Instruct-GGUF                # qwen3vl

# ── Non-unsloth: fork detection (no unsloth equivalents) ──
prism-ml/Bonsai-8B-gguf                          # prism-ml fork (ternary Q2_0, dtype 42)
YTan2000/Qwen3.6-35B-A3B-TQ3_4S                  # tq3 fork (TQ3_4S weights, dtype 46)
